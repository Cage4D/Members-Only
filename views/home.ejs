<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Members Only</title>
    <style>
        .message {
            border: 1px solid #ccc;
            padding: 10px;
            margin-bottom: 10px;
            border-radius: 5px;
        }
        .message-title {
            font-weight: bold;
            font-size: 1.1em;
        }
        .message-user {
            font-size: 0.9em;
            color: #555;
        }
    </style>
</head>
<body>
    <% if (locals.user) { %>
        <h1>Welcome back <%= user.username %></h1>
        <% if (locals.user.membership_status) { %>
            <button style="background-color: dodgerblue; border: none; border-radius: 5px; color: white;">Member</button>
        <% } else { %>
            <a href="/join-club">Join the Club</a>
        <% } %>
        <% if (locals.user.is_admin) { %>
            <button style="background-color: #212121; color: white; border: none; border-radius: 5px;">Admin</button>
        <% } else { %>
            <a href="/make-admin">PROMOTE TO ADMIN</a>
        <% } %>
        <a href="/new-message">Create New Message</a>
        <a href="/log-out">LOG OUT</a>

    <% } else { %>
        <h2>Welcome to the Members Only club!</h2>
        <a href="/sign-up">Sign Up</a>
        <a href="/log-in">Log In</a>
    <% } %>

    <h2>Messages</h2>
    <% if (messages.length === 0) { %>
        <p>No messages yet.</p>
    <% } else { %>
        <% messages.forEach(msg => { %>
            <div class="message">
                <div class="message-title"><%= msg.title %></div>
                <% if (locals.user) { %>
                    <div class="message-user">Posted by: <%= msg.user_id %> on <%= new Date(msg.created_at).toLocaleString() %></div>
                <% } else { %>
                    <div class="message-user">Posted by: Anonymous</div>
                <% } %>
                <p><%= msg.text %></p>
            </div>
        <% }) %>
    <% } %>
</body>
</html>