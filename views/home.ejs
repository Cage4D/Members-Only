<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <title>Members Only</title>
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #f9f9f9;
      margin: 0;
      padding: 2rem;
    }

    h1, h2 {
      font-weight: 600;
      margin-bottom: 1rem;
    }

    .message {
      border: 1px solid #ccc;
      padding: 1rem;
      margin-bottom: 1rem;
      border-radius: 5px;
      background-color: #fff;
    }

    .message-title {
      font-weight: 600;
      font-size: 1.1em;
      margin-bottom: 0.25rem;
    }

    .message-user {
      font-size: 0.875rem;
      color: #555;
      margin-bottom: 0.5rem;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    button, .new-message, .log-out {
      border: none;
      border-radius: 5px;
      color: white;
      padding: 0.5rem 1rem;
      cursor: pointer;
      font-weight: 500;
      margin-right: 0.5rem;
      margin-bottom: 0.5rem;
      transition: background 0.2s ease;
    }

    .new-message {
      background-color: #4f46e5;
    }

    .new-message:hover {
      background-color: #4338ca;
    }

    .log-out {
      background-color: #dc2626;
    }

    .log-out:hover {
      background-color: #b91c1c;
    }

    .member-btn {
      background-color: dodgerblue;
    }

    .member-btn:hover {
      background-color: #1e90ff;
    }

    .admin-btn {
      background-color: #212121;
    }

    .admin-btn:hover {
      background-color: #000000;
    }

    a.join-club, a.promote-admin, a.sign-up, a.log-in {
      padding: 0.5rem 1rem;
      border-radius: 5px;
      background-color: #4f46e5;
      color: white;
      display: inline-block;
      margin-right: 0.5rem;
      margin-bottom: 0.5rem;
      text-decoration: none;
      transition: background 0.2s ease;
    }

    a.join-club:hover, a.promote-admin:hover, a.sign-up:hover, a.log-in:hover {
      background-color: #4338ca;
    }

    .delete-btn {
      background-color: #dc2626;
    }

    .delete-btn:hover {
      background-color: #b91c1c;
    }
  </style>
</head>
<body>
  <% if (locals.user) { %>
    <h1>Welcome back <%= user.username %></h1>

    <% if (locals.user.membership_status) { %>
      <button class="member-btn">Member</button>
    <% } else { %>
      <a href="/join-club" class="join-club">Join the Club</a>
    <% } %>

    <% if (locals.user.is_admin) { %>
      <button class="admin-btn">Admin</button>
    <% } else { %>
      <a href="/make-admin" class="promote-admin">PROMOTE TO ADMIN</a>
    <% } %>

    <a href="/new-message" class="new-message">Create New Message</a>
    <a href="/log-out" class="log-out">LOG OUT</a>

  <% } else { %>
    <h2>Welcome to the Members Only club!</h2>
    <a href="/sign-up" class="sign-up">Sign Up</a>
    <a href="/log-in" class="log-in">Log In</a>
  <% } %>

  <h2>Messages</h2>
  <% if (messages.length === 0) { %>
    <p>No messages yet.</p>
  <% } else { %>
    <% messages.forEach(msg => { %>
      <div class="message">
        <div class="message-title"><%= msg.title %></div>
        <% if (locals.user) { %>
          <div class="message-user">Posted by: <%= msg.user_id %> on <%= new Date(msg.created_at).toLocaleString() %></div>
        <% } else { %>
          <div class="message-user">Posted by: Anonymous</div>
        <% } %>
        <p><%= msg.text %></p>

        <% if (locals.user && locals.user.is_admin) { %>
          <form action="/delete-message/<%= msg.id %>" method="POST" style="display:inline;">
            <button type="submit" class="delete-btn">Delete message</button>
          </form>
        <% } %>
      </div>
    <% }) %>
  <% } %>
</body>
</html>