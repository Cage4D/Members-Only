<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Members Only</title>
</head>
<body>
    <% if (locals.user) {%>
        <h1>Welcome back <%= user.username%></h1>
        <% if (locals.user.membership_status) { %>
            <button style="background-color: dodgerblue; border: none; border-radius: 5px; color: white;">Member</button>
        <% } else { %>
            <a href="/join-club">Join the Club</a>
        <% } %>
        <a href="/log-out">LOG OUT</a>
    <% } else { %>
        <h2>Welcome to the Members Only club!</h2>
        <a href="/sign-up">Sign Up</a>
        <a href="/log-in">Log In</a>
    <% } %>
</body>
</html>